@model Laboratorio04.Web.Models.Producto

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1>Eliminar Producto</h1>

<div class="alert alert-warning">
    ¿Confirma que desea eliminar el siguiente producto?
</div>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>

    <dt class="col-sm-2">Precio</dt>
    <dd class="col-sm-10">@string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "{0:C}", Model.Precio)</dd>

    <dt class="col-sm-2">Categoría</dt>
    <dd class="col-sm-10">@Model.Categoria</dd>
</dl>

<form asp-action="Eliminar" asp-controller="Productos" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
