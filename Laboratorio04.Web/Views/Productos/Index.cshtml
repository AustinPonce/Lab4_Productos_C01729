@model List<Laboratorio04.Web.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1>Productos</h1>

<p>
    <a class="btn btn-primary" asp-action="Crear">Crear nuevo</a>
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No hay productos registrados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th class="text-end">Precio</th>
                    <th>Categoría</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nombre</td>
                        <td class="text-end">@string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "{0:C}", item.Precio)</td>
                        <td>@item.Categoria</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Detalles" asp-route-id="@item.Id">Detalles</a>
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="visually-hidden">Acciones</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-action="Editar" asp-route-id="@item.Id">Editar</a></li>
                                    <li><a class="dropdown-item text-danger" asp-action="Eliminar" asp-route-id="@item.Id">Eliminar</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
